# ════════════════════════════════════════════════════════════════
#  NotiqAI — Najot Nur · environment template
#  Copy to `.env` and fill in real values. Never commit `.env`.
# ════════════════════════════════════════════════════════════════

# ───── App ─────
APP_NAME=NotiqAI
ENVIRONMENT=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000
# Local frontend ports (dev)
ADMIN_PORT=5173
CURATOR_PORT=5174
LANDING_PORT=5175
# Comma-separated origins allowed by CORS (admin, curator, mobile webview, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ───── Frontends (Vite) ─────
# Each frontend reads VITE_API_URL at build/dev time.
# Use /api/v1 if nginx proxies same-origin; or a full URL for cross-origin.
VITE_API_URL_ADMIN=/api/v1
VITE_API_URL_CURATOR=/api/v1
# (landing has no API)

# ───── PostgreSQL ─────
POSTGRES_USER=notiq
POSTGRES_PASSWORD=notiq_dev_password
POSTGRES_DB=notiqai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async driver URL used by the app (asyncpg). Overrides the parts above if set.
DATABASE_URL=postgresql+asyncpg://notiq:notiq_dev_password@localhost:5432/notiqai

# ───── Redis ─────
REDIS_URL=redis://localhost:6379/0

# ───── Auth / JWT ─────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
# OTP for phone login
OTP_TTL_SECONDS=120
OTP_LENGTH=6

# ───── OAuth: Google ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ───── Telegram Verification Codes ─────
# Register an app at https://my.telegram.org to get these. The service
# sends a 6-digit code to the user's official "Verification Codes" chat
# in their Telegram app — no custom bot interaction required.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# StringSession from `python -m app.scripts.telegram_login`
TELEGRAM_SESSION=

# ───── SMS gateway (phone OTP) — Eskiz.uz ─────
SMS_PROVIDER=mock                # mock | eskiz | playmobile
# Eskiz.uz credentials (https://eskiz.uz)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# ───── AI ─────
# AI_PROVIDER controls which LLM powers speech / voice / observation analysis.
# mock → deterministic (offline). claude → Anthropic. gemini → Google Gemini.
AI_PROVIDER=mock

# Anthropic Claude (used when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Google Gemini (used when AI_PROVIDER=gemini)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Override if you proxy Gemini through OpenRouter / LiteLLM / etc.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Speech-to-text (optional, server-side transcription before analysis).
# mock → none (client sends transcript). groq → Groq Whisper large-v3 with
# word-level timestamps (recommended, TZ §3.1).
STT_PROVIDER=mock                # mock | groq | openai_whisper | google
STT_API_KEY=
# Default transcription language and audio size cap.
STT_LANGUAGE=uz                  # uz | ru | en
STT_MAX_AUDIO_MB=50

# Groq Whisper (used when STT_PROVIDER=groq). Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ───── AMOCRM (lead push on registration) ─────
AMOCRM_BASE_URL=
AMOCRM_ACCESS_TOKEN=
AMOCRM_PIPELINE_ID=
AMOCRM_RESPONSIBLE_USER_ID=

# ───── Object storage (audio, video, certificates) ─────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=notiqai-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Local fallback when S3 is not configured
LOCAL_MEDIA_DIR=./media

# ───── Payments (later phase — placeholders) ─────
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
UZUM_NASIYA_API_KEY=
ATMOS_STORE_ID=
ATMOS_CONSUMER_KEY=
ATMOS_CONSUMER_SECRET=

# ───── Monitoring ─────
SENTRY_DSN=

# ───── Push notifications (FCM) ─────
# When FCM_ENABLED=true AND firebase-service-account.json exists, the backend
# delivers real FCM pushes. Otherwise it still records notifications in the DB
# (visible in the mobile app) but does not push to the device tray.
# Steps to enable: see docs/firebase_setup.md
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
FCM_PROJECT_ID=
