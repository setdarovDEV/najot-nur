# ════════════════════════════════════════════════════════════════
#  NotiqAI — PRODUCTION environment for Dokploy / self-hosted.
#
#  How to use:
#    1. Copy this file to `.env` on the server
#       (or paste the variables into Dokploy's "Environment" tab).
#    2. Replace every CHANGE_ME_* placeholder with a real value.
#    3. `openssl rand -hex 32` generates strong secrets.
#
#  Variables marked REQUIRED must be set — the compose file will
#  refuse to start without them.
# ════════════════════════════════════════════════════════════════

# ───── App ─────
APP_NAME=NotiqAI
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000
# Comma-separated CORS origins.
# • Same-origin (admin and api both behind nginx): leave default.
# • Cross-origin: list every https://*.notiqlik.uz you serve.
CORS_ORIGINS=https://notiqlik.uz,https://admin.notiqlik.uz,https://curator.notiqlik.uz,https://api.notiqlik.uz

# ───── Public domain / base URLs ─────
# Each frontend reads its own VITE_API_URL* at build time. Set to the
# publicly reachable API base, NO trailing slash.
#   Same-origin:  /api/v1
#   Cross-origin: https://api.notiqlik.uz/api/v1
VITE_API_URL_ADMIN=/api/v1
VITE_API_URL_CURATOR=/api/v1
# (landing has no API)

# ───── Frontend build-time URLs (Dokploy passes these as build args) ─────
# Keep these in sync with the nginx server_name entries.
PUBLIC_DOMAIN=notiqlik.uz
ADMIN_DOMAIN=admin.notiqlik.uz
CURATOR_DOMAIN=curator.notiqlik.uz
API_DOMAIN=api.notiqlik.uz

# ───── PostgreSQL (internal docker network) ─────
# REQUIRED — set a strong password.
POSTGRES_USER=notiq
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=notiqai
# These are overridden by docker-compose.yml (kept for reference).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://notiq:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/notiqai

# ───── Redis (internal docker network) ─────
REDIS_URL=redis://redis:6379/0

# ───── Auth / JWT ─────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
OTP_TTL_SECONDS=120
OTP_LENGTH=6

# ───── OTP delivery ─────
# telegram → user must /start the bot first
# sms      → uses SMS_API_URL/API_TOKEN below
OTP_PROVIDER=telegram

# ───── OAuth: Google ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ───── OAuth: Telegram Login Widget ─────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ───── Telegram Login (Verification Codes) ─────
# Register an app at https://my.telegram.org → get api_id / api_hash.
# Then run `python -m app.scripts.telegram_login` once and paste the
# StringSession here. Telegram will then send 6-digit codes to the
# user's official "Verification Codes" chat.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# ───── SMS gateway (Eskiz / Play Mobile) ─────
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_TOKEN=
SMS_SENDER=NotiqAI
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# ───── AI providers ─────
# mock | groq | gemini | dual | claude
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GROQ_API_KEY=
GROQ_LLM_MODEL=qwen/qwen3-32b
GROQ_STT_MODEL=whisper-large-v3
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ───── Speech-to-text ─────
STT_PROVIDER=mock
STT_API_KEY=
STT_LANGUAGE=uz
STT_MAX_AUDIO_MB=50

# ───── Quiz intro video cap (MB) ─────
QUIZ_VIDEO_MAX_MB=200

# ───── AMOCRM (lead push) ─────
AMOCRM_BASE_URL=
AMOCRM_ACCESS_TOKEN=
AMOCRM_PIPELINE_ID=
AMOCRM_RESPONSIBLE_USER_ID=

# ───── Object storage (S3 / MinIO) — optional ─────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=notiqai-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
# When S3 is empty, the backend writes here (mounted as a Docker volume).
LOCAL_MEDIA_DIR=/app/media

# ───── Payments ─────
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
UZUM_NASIYA_API_KEY=
ATMOS_STORE_ID=
ATMOS_CONSUMER_KEY=
ATMOS_CONSUMER_SECRET=

# ───── Monitoring ─────
SENTRY_DSN=

# ───── Push notifications (FCM) ─────
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json
FCM_PROJECT_ID=

# ───── Deployment knobs ─────
# Set to "true" on the FIRST deploy to populate demo data
# (idempotent — safe to leave true if you re-run).
RUN_SEEDS=false
# Gunicorn worker count (2 * CPU + 1 is a good starting point).
WEB_CONCURRENCY=2

# ───── SSL ─────
# Dokploy's Traefik handles Let's Encrypt automatically when you add
# domains in the UI. No action needed in this file.
# (Dokploy reads the certbot-style EMAIL for ACME registration.)
