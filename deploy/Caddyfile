# ════════════════════════════════════════════════════════════════
#  NotiqAI — Caddy reverse proxy.
#  Auto-issues Let's Encrypt certs for ALL listed domains on first
#  start. Certs auto-renew before expiry.
#
#  All hostnames route to the same internal nginx (port 8080 on
#  the host, mapped from the docker network). Nginx then does
#  Host-based routing to backend/admin/curator/landing/grafana.
#
#  Add/remove domains here and run `caddy reload` (or just
#  recreate the caddy container: `docker compose restart caddy`).
# ════════════════════════════════════════════════════════════════

notiqlik.uz,
www.notiqlik.uz,
admin.notiqlik.uz,
curator.notiqlik.uz,
api.notiqlik.uz,
grafana.notiqlik.uz {
    encode zstd gzip

    reverse_proxy nginx:80 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP        {remote_host}
    }
}
