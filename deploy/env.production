# ════════════════════════════════════════════════════════════════
#  NotiqAI — PRODUCTION environment template
#  Edit the placeholders, then copy to .env on the server.
#  NEVER commit the populated .env to git.
# ════════════════════════════════════════════════════════════════

# ───── App ─────
APP_NAME=NotiqAI
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000

# Server IP host (no domain yet). Add more origins as you add domains.
CORS_ORIGINS=http://45.138.159.219,http://45.138.159.219:5173

# ───── PostgreSQL (internal docker network) ─────
POSTGRES_USER=notiq
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=notiqai
# These two are overridden by docker-compose.prod.yml, kept for tooling.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://notiq:CHANGE_ME_STRONG_PASSWORD@postgres:5432/notiqai

# ───── Redis (internal docker network) ─────
REDIS_URL=redis://redis:6379/0

# ───── Auth / JWT ─────
# openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
OTP_TTL_SECONDS=120
OTP_LENGTH=6

# ───── OAuth: Google ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ───── OAuth: Telegram ─────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ───── SMS ─────
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_TOKEN=
SMS_SENDER=NotiqAI

# ───── AI ─────
# mock  → offline deterministic
# claude / gemini → real LLM
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

STT_PROVIDER=mock
STT_API_KEY=

# ───── AMOCRM ─────
AMOCRM_BASE_URL=
AMOCRM_ACCESS_TOKEN=
AMOCRM_PIPELINE_ID=
AMOCRM_RESPONSIBLE_USER_ID=

# ───── Object storage (S3) ─────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=notiqai-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
LOCAL_MEDIA_DIR=/app/media

# ───── Payments (later) ─────
UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=
UZUM_NASIYA_API_KEY=
ATMOS_STORE_ID=
ATMOS_CONSUMER_KEY=
ATMOS_CONSUMER_SECRET=

# ───── Monitoring ─────
SENTRY_DSN=

# ───── FCM ─────
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json
FCM_PROJECT_ID=

# ───── Gunicorn workers (override at runtime) ─────
WEB_CONCURRENCY=2
